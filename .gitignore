```toml
# TOML-specific ignores for extension builds/configs
*.toml.bak
*.toml~
*.backup/

# If extension involves compiled components
*.so
*.dylib
*.dll
*.exe
*.o
*.obj

# Common build artifacts
build/
dist/
target/
out/

# Dependencies
node_modules/
vendor/
deps/

# Environment and cache
.env
.env.local
.env.*
.cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
```

